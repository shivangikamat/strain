# Copy to ".env" in the repo root if you want FastMCP to load these automatically
# (FastMCP reads .env for variables prefixed FASTMCP_ — see mcp package docs.)

# --- MCP transport (STRAIN wrapper) ---
# stdio = Cursor / Claude Desktop local. sse = URL + ngrok for Prompt Opinion.
STRAIN_MCP_TRANSPORT=stdio

# Set to 1 when exposing MCP behind ngrok / unknown Host header (dev only).
STRAIN_MCP_RELAX_DNS=0

# --- FastMCP HTTP/SSE (used when STRAIN_MCP_TRANSPORT=sse or streamable-http) ---
FASTMCP_HOST=127.0.0.1
FASTMCP_PORT=8765
# FASTMCP_SSE_PATH=/sse
# FASTMCP_MESSAGE_PATH=/messages/

# --- Data paths (optional overrides) ---
# STRAIN_EMOTIONS_CSV=/absolute/path/to/emotions.csv
# STRAIN_DREAMER_PROCESSED=/absolute/path/to/data/processed/dreamer
