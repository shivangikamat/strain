# ── Secrets / environment ──────────────────────────────────────────────────────
# NEVER commit real .env files — copy .env.example to .env and fill in your keys
.env
.env.local
.env.*.local
# .env.example is intentionally NOT ignored — it is the safe template

# ── Python ─────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd
.Python

# ── Virtual environments ────────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
.env/

# ── Distribution / packaging ────────────────────────────────────────────────────
build/
dist/
*.egg-info/
*.egg
MANIFEST

# ── Testing ─────────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/
nosetests.xml

# ── Type checking / linting ─────────────────────────────────────────────────────
.mypy_cache/
.ruff_cache/

# ── IDEs ────────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Local AI / assistant tooling ───────────────────────────────────────────────
.codex
.claude/
.cursor/
.windsurf/
.roo/

